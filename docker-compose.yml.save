# Specifies the Docker Compose version
version: '3.8'

# This is where we define all our services (containers)
services:

  # PostgreSQL Database for user/ngo data
  postgres:
    image: postgres:15-alpine
    container_name: catalyst-postgres
    restart: always
    environment:
      POSTGRES_USER: catalyst_user
      POSTGRES_PASSWORD: catty123
      POSTGRES_DB: catalyst_users
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./db-init/init-postgres.sql:/docker-entrypoint-initdb.d/init.sql
    ports:
      - "5432:5432"
    networks:
      - catalyst-net

  # CockroachDB for the audit ledger
  cockroachdb:
    image: virag/cockroachdb-s390x:23.1.2
    container_name: catalyst-cockroach
    restart: always
    command: /home/builduser/cockroach/cockroach start-single-node --insecure --listen-addr=0.0.0.0:26257 --http-addr=0.0.0.0:8080

    volumes:
      - cockroach_data:/cockroach/cockroach-data
      - ./db-init/init-cockroach.sql:/docker-entrypoint-initdb.d/init.sql
    ports:
      - "26257:26257"
      - "8081:8080"
    networks:
      - catalyst-net

  # Main API Service
  main-api:
    build: ./main-api
    container_name: catalyst-main-api
    restart: always
    ports:
      - "3000:3000"
    env_file:
      - ./main-api/.env
    volumes:
         - ./main-api/uploads:/usr/src/app/uploads
    networks:
      - catalyst-net
    depends_on:
      - postgres
      - cockroachdb

  # Verification AI Agent
  verification-agent:
    build: ./verification-agent
    container_name: catalyst-verification-agent
    restart: always
    ports:
      - "3001:3001"
    networks:
      - catalyst-net

  # Price-Checking AI Agent
  price-checking-agent:
    build: ./price-checking-agent
    container_name: catalyst-price-checking-agent
    restart: always
    ports:
      - "3002:3002"
    networks:
      - catalyst-net

  # Document Analysis AI Agent
  document-analysis-agent:
    build: ./document-analysis-agent
    container_name: catalyst-doc-analysis-agent
    restart: always
    ports:
      - "3003:3003"
    networks:
      - catalyst-net

  # Impact Assessment AI Agent
  impact-assessment-agent:
    build: ./impact-assessment-agent
    container_name: catalyst-impact-agent
    restart: always
    ports:
      - "3004:3004"
    networks:
      - catalyst-net

# Defines the shared network for containers to communicate
networks:
  catalyst-net:
    driver: bridge

# Defines the persistent storage volumes
volumes:
  postgres_data:
  cockroach_data:
